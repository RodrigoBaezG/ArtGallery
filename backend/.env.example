# Copia este archivo a backend/.env y completa los valores reales.

# --- Conexión local a PostgreSQL (modo desarrollo) ---
DB_USER=postgres
DB_HOST=localhost
DB_NAME=artgallery
DB_PASSWORD=tu_password
DB_PORT=5432

# --- Alternativa: cadena de conexión completa (Render, Railway, Neon, etc.) ---
# Si DATABASE_URL está definida, tiene prioridad sobre las variables sueltas.
# DATABASE_URL=postgres://user:password@host:5432/artgallery

# --- Servidor ---
PORT=5000

# --- Entorno ---
# Pon NODE_ENV=production en deploy para activar SSL contra la base remota.
NODE_ENV=development
